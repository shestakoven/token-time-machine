# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Google AI (Genkit) - Optional for enhanced AI features
GOOGLE_API_KEY=your_google_ai_key

# Analytics & Tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga_measurement_id

# Affiliate Partner IDs (Replace with your actual referral codes)
BINANCE_REF_CODE=your_binance_ref
COINBASE_REF_CODE=your_coinbase_ref
KUCOIN_REF_CODE=your_kucoin_ref
LEDGER_REF_CODE=your_ledger_ref

# Stripe (for subscription payments)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Production URLs
NEXT_PUBLIC_APP_URL=http://localhost:9002